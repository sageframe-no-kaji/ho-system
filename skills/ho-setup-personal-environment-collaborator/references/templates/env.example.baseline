# .env.example
#
# Ho System .env.example baseline.
# This file is committed; .env (with real values) is gitignored.
# Document each variable: what it configures, what shape the value should have.
#
# Convention:
#   - Section dividers separate logical groups.
#   - REQUIRED variables marked.
#   - Optional variables have inline default examples.
#   - Project prefix on variable names (e.g., MYPROJ_*) to avoid collision.

# ─── Application core ───────────────────────────────────────────────────
# REQUIRED
MYPROJ_ENV=                    # development | staging | production
MYPROJ_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR

# ─── Server / network ───────────────────────────────────────────────────
# REQUIRED for services
MYPROJ_HOST=0.0.0.0
MYPROJ_PORT=8000

# ─── Database ───────────────────────────────────────────────────────────
# REQUIRED for projects with persistence
MYPROJ_DB_URL=                 # e.g., postgresql://user:pass@host:5432/dbname
MYPROJ_DB_POOL_SIZE=5

# ─── External APIs ──────────────────────────────────────────────────────
# Document each: what the key is for, where to obtain it, what it looks like.
# MYPROJ_API_KEY_<SERVICE>=

# ─── Storage paths (when applicable) ────────────────────────────────────
# Absolute paths to data directories. Required when the project reads/writes
# files outside the repo.
# MYPROJ_DATA_ROOT=/opt/services/<project>/data

# ─── Feature flags ──────────────────────────────────────────────────────
# Boolean toggles for optional behaviors.
# MYPROJ_FEATURE_<NAME>=false

# ─── Observability (optional) ───────────────────────────────────────────
# MYPROJ_SENTRY_DSN=
# MYPROJ_OTEL_ENDPOINT=
