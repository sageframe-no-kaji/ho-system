{
  "permissions": {
    "allow": [
      "Read(<VAULT_ROOT>/**)",
      "Read(/tmp/**)",
      "Edit(<VAULT_ROOT>/**)",
      "Edit(/tmp/**)",
      "Write(<VAULT_ROOT>/**)",
      "Write(/tmp/**)",
      "Bash(uv:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pre-commit:*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(cargo:*)",
      "Bash(swift:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(make:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /Users:*)",
      "Bash(rm -rf ~:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Read(**/.env)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/.gnupg/**)",
      "Edit(**/.env)",
      "Edit(**/.ssh/**)",
      "Edit(<HOME>/.zshrc)",
      "Edit(<HOME>/.bashrc)",
      "Edit(<HOME>/.zprofile)",
      "Edit(<HOME>/.bash_profile)",
      "Write(**/.env)",
      "Write(**/.ssh/**)"
    ]
  },
  "theme": "<light or dark>"
}
